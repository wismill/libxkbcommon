		symbols[4]= [                      KP_Divide,                      KP_Divide,                       division,                          U2300,                          U2215,                       NoSymbol,                          U2223,                       NoSymbol ],
		actions[4]= [ SetPtrDflt(affect=button,button=1), SetPtrDflt(affect=button,button=1),                     NoAction(),                     NoAction(),                     NoAction(),                     NoAction(),                     NoAction(),                     NoAction() ]
